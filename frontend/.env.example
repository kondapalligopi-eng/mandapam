# Web3Forms access key — makes the Contact and "List your business" forms
# deliver submissions to your email (no backend required).
#
# Setup (takes ~1 minute):
#   1. Go to https://web3forms.com
#   2. Enter your email (e.g. kondapalli.gopi@gmail.com) and submit
#   3. Copy the access key emailed to you
#   4. Create a file named ".env.local" in this folder (frontend/) with:
#        VITE_WEB3FORMS_ACCESS_KEY=your-access-key-here
#   5. Restart the dev server (npm run dev)
#
# Note: this key is safe to expose in the browser — that's how Web3Forms works.

VITE_WEB3FORMS_ACCESS_KEY=
